    },
    {
      "id": "legend-t",
      "type": "text",
      "x": 1870,
      "y": 937.9999999999999,
      "width": 601.666656594656,
      "height": 475,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "xfLuR86EGcb_eQ-zgzvzA"
      ],
      "roundness": null,
      "seed": 53,
      "version": 75,
      "versionNonce": 102506045,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774528516853,
      "link": null,
      "locked": false,
      "text": "flow details\n(1) partner sends command through private channel.\n(2) edge validates identity, quota, schema, idempotency.\n(3) accepted command enters internal API and event bus.\n(4) push orchestrator produces provider-specific delivery\ntasks.\n(5) delivery statuses are emitted back to event bus.\n(6) all operational and partner events stream to analytics.\n(7) streaming ETL normalizes and enriches to canonical\nmodel.\n(8) data quality checks route bad records to quarantine.\n(9) trusted data lands in DWH/Lakehouse and serves\nBI/ML.\n\nsuggested SLOs\n- command p95 latency < 300 ms\n- push enqueue success > 99.95%\n- end-to-end data freshness < 5 min\n- schema compatibility violations = 0 in prod",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "flow details\n(1) partner sends command through private channel.\n(2) edge validates identity, quota, schema, idempotency.\n(3) accepted command enters internal API and event bus.\n(4) push orchestrator produces provider-specific delivery tasks.\n(5) delivery statuses are emitted back to event bus.\n(6) all operational and partner events stream to analytics.\n(7) streaming ETL normalizes and enriches to canonical model.\n(8) data quality checks route bad records to quarantine.\n(9) trusted data lands in DWH/Lakehouse and serves BI/ML.\n\nsuggested SLOs\n- command p95 latency < 300 ms\n- push enqueue success > 99.95%\n- end-to-end data freshness < 5 min\n- schema compatibility violations = 0 in prod",
      "lineHeight": 1.25,
      "baseline": 463,
      "index": "ap",
      "frameId": null,
      "autoResize": false
    },
